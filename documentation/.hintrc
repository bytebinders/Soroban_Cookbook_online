{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "backdrop-filter"
        ]
      }
    ],
    "image-alt-text": "error",
    "label": "error",
    "button-type": "warning",
    "meta-viewport": "off",
    "no-inline-styles": "off"
  }
}